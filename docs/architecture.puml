        created_at, updated_at : TIMESTAMP
        --
        INDEX idx_..._user_code
        INDEX idx_..._type
    }

    ' ── Database FK relationships ──
    user_tbl }|--|| role_user : "FK CASCADE"
    applicant_info }|--o| sessions : "FK CASCADE"
    applicant_status ||--|| applicant_info : "FK CASCADE"
    program_info ||--|| applicant_info : "FK CASCADE"
    application_info ||--|| applicant_info : "FK CASCADE"
    ratings }|--|| applicant_info : "FK CASCADE"

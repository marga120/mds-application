' ============================================================================
' PACKAGE 6 — DATABASE SCHEMA
' ============================================================================
package "Database Schema (PostgreSQL)" as DB <<Rectangle>> #F5F5F5 {

    entity role_user {
        * **id** : SERIAL PK
        --
        name : VARCHAR(50) UNIQUE
    }

    entity "\"user\"" as user_tbl {
        * **id** : SERIAL PK
        --
        first_name : VARCHAR(50)
        last_name : VARCHAR(50)
        email : VARCHAR(100) UNIQUE
        password : VARCHAR(100)
        role_user_id : INT FK → role_user
        created_at : TIMESTAMP
        updated_at : TIMESTAMP
        --
        <<trigger>> update_user_updated_at
        <<trigger>> user_deletion_trigger
    }

    entity sessions {
        * **id** : SERIAL PK
        --
        program_code : VARCHAR(10)
        program : VARCHAR(50)
        session_abbrev : VARCHAR(10)
        year : INT
        name : VARCHAR(30)
        description : VARCHAR(100)
        campus : VARCHAR(10) CHECK (UBC-V|UBC-O)
        is_archived : BOOLEAN
        created_at : TIMESTAMP
        updated_at : TIMESTAMP
        --
        UNIQUE(campus, program_code, year, session_abbrev)
        <<trigger>> update_sessions_updated_at
    }

    entity applicant_info {
        * **user_code** : VARCHAR(10) PK
        --
        session_id : INT FK → sessions CASCADE
        interest_code, interest : VARCHAR
        title, family_name, given_name : VARCHAR
        middle_name, preferred_name : VARCHAR
        former_family_name : VARCHAR
        gender_code, gender : VARCHAR
        country_birth_code, country_birth : VARCHAR
        date_birth : DATE
        age : INT
        country_citizenship_code/citizenship : VARCHAR
        dual_citizenship_code/citizenship : VARCHAR
        primary_spoken_lang_code/lang : VARCHAR
        other_spoken_lang_code/lang : VARCHAR
        visa_type_code, visa_type : VARCHAR
        country_code, country : VARCHAR
        address_line1/2, city, province : VARCHAR
        postal_code, telephone(s), email : VARCHAR
        aboriginal, first_nation, inuit : VARCHAR(3)
        metis, aboriginal_not_specified : VARCHAR(3)
        aboriginal_info, racialized : VARCHAR
        academic_history_code/history : VARCHAR
        ubc_academic_history : TEXT
        created_at, updated_at : TIMESTAMP
    }

    entity applicant_status {
        * **user_code** : VARCHAR(10) PK FK → applicant_info CASCADE
        --
        student_number : VARCHAR(100)
        app_start, submit_date : DATE
        status_code, status : VARCHAR
        detail_status : VARCHAR(250)
        created_at, updated_at : TIMESTAMP
    }

    entity program_info {
        * **user_code** : VARCHAR(10) PK FK → applicant_info CASCADE
        --
        program_code : VARCHAR(10)
        program : VARCHAR(100)
        session : VARCHAR(50)
    }

    entity status_configuration {
        * **id** : SERIAL PK
        --
        status_name : VARCHAR(100) UNIQUE
        display_order : INT
        badge_color : VARCHAR(50)
        is_active : BOOLEAN
        is_default : BOOLEAN
        created_at, updated_at : TIMESTAMP
    }

    entity application_info <<flaw>> #FFCCCC {
        * **user_code** : VARCHAR(10) PK FK → applicant_info CASCADE
        --
        sent : VARCHAR(100) DEFAULT 'Not Reviewed'
        ····**← soft ref to status_configuration.status_name**
        ····**← no FK constraint — string match only**
        full_name : VARCHAR(100)
        canadian : BOOLEAN
        english : BOOLEAN
        english_status : VARCHAR(50)
        english_description : VARCHAR(3000)
        english_comment : VARCHAR(255)
        cs, stat, math : TEXT
        additional_comments : TEXT
        gpa : VARCHAR(50)
        highest_degree, degree_area : VARCHAR(50)
        mds_v, mds_cl, mds_o : VARCHAR(10)
        scholarship : VARCHAR(20) CHECK (Yes|No|Undecided)
    }

    entity ratings {
        * **(user_id, user_code)** : Composite PK
        --
        user_id : INT FK → "user" CASCADE
        user_code : VARCHAR(10) FK → applicant_info CASCADE
        rating : DECIMAL(3,1) CHECK 0..10
        user_comment : VARCHAR(2000)
        created_at, updated_at : TIMESTAMP
        --
        <<trigger>> update_ratings_updated_at
    }

    entity institution_info {
        * **(user_code, institution_number)** : Composite PK
        --
        user_code : VARCHAR(10) FK → applicant_info CASCADE
        institution_number : INT
        institution_code : VARCHAR(50)
        full_name : VARCHAR(1000)
        country : VARCHAR(100)
        start_date, end_date : DATE
        program_study : VARCHAR(250)
        degree_confer_code/confer : VARCHAR(100)
        date_confer : DATE
        credential_receive_code/receive : VARCHAR
        expected_confer_date : DATE
        expected_credential_code/credential : VARCHAR
        honours : VARCHAR(5000)
        fail_withdraw : VARCHAR(3)
        reason : VARCHAR(3000)
        gpa : VARCHAR(50)
        created_at, updated_at : TIMESTAMP
        --
        <<trigger>> institution_info_deletion_trigger
    }

    entity toefl {
        * **(user_code, toefl_number)** : Composite PK
        --
        FK → applicant_info CASCADE
        registration_num, date_written : VARCHAR/DATE
        total_score, listening : VARCHAR
        structure_written, reading, speaking : VARCHAR
        mybest_total, mybest_date : VARCHAR/DATE
        mybest_listening/date : VARCHAR/DATE
        mybest_writing/date : VARCHAR/DATE
        mybest_reading/date : VARCHAR/DATE
        mybest_speaking/date : VARCHAR/DATE
        created_at, updated_at : TIMESTAMP
    }

    entity ielts {
        * **(user_code, ielts_number)** : Composite PK
        --
        FK → applicant_info CASCADE
        candidate_num, date_written : VARCHAR/DATE
        total_band_score : VARCHAR
        listening, reading, writing, speaking : VARCHAR
        created_at, updated_at : TIMESTAMP
    }

    entity duolingo {
        * **user_code** : VARCHAR(10) PK FK → applicant_info
        --
        score : INTEGER
        description : TEXT
        date_written : DATE
        created_at, updated_at : TIMESTAMP
    }

    entity gre {
        * **user_code** : PK FK → applicant_info CASCADE
        --
        reg_num, date_written : VARCHAR/DATE
        verbal, verbal_below : VARCHAR
        quantitative, quantitative_below : VARCHAR
        writing, writing_below : VARCHAR
        subject_tests, subject_reg_num : VARCHAR

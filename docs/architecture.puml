    toefl }|--|| applicant_info : "FK CASCADE"
    ielts }|--|| applicant_info : "FK CASCADE"
    duolingo ||--|| applicant_info : "FK (no explicit CASCADE)"
    gre ||--|| applicant_info : "FK CASCADE"
    gmat ||--|| applicant_info : "FK CASCADE"
    melab ||--|| applicant_info : "FK CASCADE"
    pte ||--|| applicant_info : "FK CASCADE"
    cael ||--|| applicant_info : "FK CASCADE"

' ============================================================================
' PACKAGE 4 — UTILS LAYER
' ============================================================================
package "Utils Layer" as UTL <<Rectangle>> #FFEEEE {

    class "utils.database" as db_util <<module>> {
        +DB_CONFIG: dict
        +get_db_connection(): Connection
        +read_schema_file(): str
        +execute_schema_statements(cursor, sql)
        +init_database(): bool
        +check_uploaded_at_column(): bool
    }

    class "utils.db_helpers" as db_help <<module>> {
        +db_connection(cursor_factory): ContextMgr
        +db_transaction(cursor_factory): ContextMgr
        +fetch_one(query, params): dict
        +fetch_all(query, params): list
        +execute_query(query, params, returning): dict
        +execute_many(query, params_list)
    }

    class "utils.activity_logger" as logger <<module>> {
        +log_activity(action_type, target_entity,
        ····target_id, old_value, new_value,
        ····additional_metadata, user): tuple
        +get_activity_logs(limit, offset,
        ····filter_action_type, filter_user_search): tuple
        -- tables --
        activity_log, "user", role_user
    }

    class "utils.csv_helpers" as csv_help <<module>> {
        +clean_value(value): Any
        +clean_row(row): dict
        +clean_rows(rows): list
        +rows_to_csv_string(rows, fieldnames): str
        +create_csv_response(rows, filename): Response
        +generate_export_filename(prefix, count): str
    }

    class CSVWriter {
        -output: StringIO
        -writer: csv.writer
        --
        +__enter__()
        +__exit__()
        +writerow(row)
        +writerows(rows)
        +write_dict_row(row, fieldnames)
        +write_header(headers)
        +write_spacer()
        +write_section_header(title)
        +getvalue(): str
        +make_response(filename): Response
    }

    class "utils.permissions" as perms <<module>> {
        +require_authenticated(f): decorator
        +require_admin(f): decorator
        +require_faculty_or_admin(f): decorator
        +require_not_viewer(f): decorator
        +check_permission(required_role): decorator
    }

    class ScoreField <<dataclass>> {
        +db_column: str
        +csv_suffix: str
        +field_type: str = 'score'
        +csv_column_override: Optional[str]
        --
        +get_csv_column(prefix): str
        +extract_value(row, prefix): Any
    }

    class TestScoreConfig <<dataclass>> {
        +table_name: str
        +fields: List[ScoreField]
        +number_field: Optional[str]
        +max_entries: int = 1
        +prefix_pattern: str
        +check_fields: List[str]
        +has_single_entry: bool = True
        --
        +get_prefix(entry_num): str
    }

    class "utils.test_score_helpers" as tsh <<module>> {
        +convert_id_to_string(value): str
        +convert_score(value): str
        +parse_date(value): date
        +build_insert_query(config): str
        +has_score_data(row, config, prefix): bool
        +get_old_records(cursor, config, code): dict
        +process_test_score(code, row, cursor, time, config): bool
        +process_all_test_scores(code, row, cursor, time): bool
        -- pre-configured constants --
        TOEFL_CONFIG, IELTS_CONFIG,
        MELAB_CONFIG, PTE_CONFIG,
        CAEL_CONFIG, CELPIP_CONFIG,
        ALT_ELPP_CONFIG, GRE_CONFIG,
        GMAT_CONFIG
    }

    ' Composition: csv_helpers contains CSVWriter
    csv_help *-- CSVWriter
    ' Composition: TestScoreConfig contains ScoreField
    TestScoreConfig *-- ScoreField
    ' db_helpers depends on database
    db_help ..> db_util : uses get_db_connection()
}


